{
  "paths": {
    "input_spod": "IN/SPOD",
    "output_db_dir": "OUT/DB",
    "logs": "log"
  },
  "database": {
    "filename": "tournament_admin.sqlite"
  },
  "database_model": {
    "comment_ru": "Схема SQLite задаётся в коде (src/db.py, init_schema), не в этом файле. Все листы используют одну таблицу строк; заголовки CSV не создают отдельных колонок — каждая строка листа хранится как JSON в cells_json.",
    "registry_table": "sheet",
    "all_sheets_data_table": "data_row",
    "relationship_ru": "data_row.sheet_id ссылается на sheet.id; логический «лист» — строка в sheet с полем code (как в sheets[].code)."
  },
  "sheet_bindings": [
    {
      "code": "CONTEST-DATA",
      "title": "Конкурсы",
      "csv_file": "CONTEST (PROM) 09-04 v1.csv"
    },
    {
      "code": "GROUP",
      "title": "Группы / уровни",
      "csv_file": "GROUP (PROM) 09-04 v1.csv"
    },
    {
      "code": "INDICATOR",
      "title": "Показатели",
      "csv_file": "INDICATOR (PROM) 09-04 v1.csv"
    },
    {
      "code": "REWARD",
      "title": "Награды",
      "csv_file": "REWARD (PROM) 09-04 v1.csv"
    },
    {
      "code": "REWARD-LINK",
      "title": "Связи конкурс — группа — награда",
      "csv_file": "REWARD-LINK (PROM) 09-04 v1.csv"
    },
    {
      "code": "TOURNAMENT-SCHEDULE",
      "title": "Расписание турниров",
      "csv_file": "SCHEDULE (PROM) 09-04 v1.csv"
    }
  ],
  "server": {
    "host": "127.0.0.1",
    "port": 8765
  },
  "logging": {
    "level": "INFO",
    "base_name": "admin"
  },
  "consistency": {
    "mode": "warn",
    "comment": "strict — не сохранять при ошибках; warn — сохранять с флагом; soft — только подсветка"
  },
  "editor_long_text_threshold": 140,
  "editor_textareas": [
    {
      "sheet_code": "CONTEST-DATA",
      "hints": [
        {
          "column": "CONTEST_DESCRIPTION",
          "min_rows": 6,
          "max_rows": 18
        },
        {
          "column": "FULL_NAME",
          "min_rows": 2,
          "max_rows": 8
        }
      ]
    },
    {
      "sheet_code": "REWARD",
      "hints": [
        {
          "column": "REWARD_DESCRIPTION",
          "min_rows": 6,
          "max_rows": 20
        },
        {
          "column": "FULL_NAME",
          "min_rows": 2,
          "max_rows": 10
        }
      ]
    },
    {
      "sheet_code": "INDICATOR",
      "hints": [
        {
          "column": "FULL_NAME",
          "min_rows": 2,
          "max_rows": 8
        }
      ]
    }
  ],
